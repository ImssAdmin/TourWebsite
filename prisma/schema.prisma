generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

model CustomData {
  id        String   @id @default(uuid())
  data      Json
  updatedAt DateTime @updatedAt
}

model Contact {
  id        String   @id @default(uuid())
  name      String
  phone     String
  email     String?
  service   String?
  message   String?
  createdAt DateTime @default(now())
}
